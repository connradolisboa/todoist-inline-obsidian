{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowSyntheticDefaultImports": true,
		"moduleResolution": "node",
		"importHelpers": false,
		"isolatedModules": true,
		"strictNullChecks": true,
		"lib": [
			"ES6",
			"DOM"
		]
	},
	"include": [
		"**/*.ts"
	]
}
